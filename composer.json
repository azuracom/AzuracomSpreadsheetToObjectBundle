{
    "name": "azuracom/spreadsheet-to-object-bundle",
    "type": "symfony-bundle",
    "description": "Symfony spreadsheet",
    "keywords": [
        "procespreadsheetss",
        "symfony"
    ],
    "authors": [
        {
            "name": "Thibaut DUMALIN",
            "email": "tdumalin@azuracom.com"
        }
    ],
    "require": {
        "php": ">=7.2",
        "symfony/validator": ">=3.4",
        "symfony/event-dispatcher": ">=3.4",
        "phpoffice/phpspreadsheet": "^1.0",
        "symfony/form": ">=3.4",
        "symfony/options-resolver": ">=3.4"
    },
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Azuracom\\SpreadsheetToObject\\": ""
        }
    }
}
